# Copy this file to .env and update values for your environment.
POSTGRES_USER=bi_user
POSTGRES_PASSWORD=bi_password
POSTGRES_DB=bi_manager
POSTGRES_VOLUME_NAME=bi-postgres-data
FRONTEND_PORT=8080

# Used by seed_production.py when run inside bi-manager (docker compose exec ...).
# These are passed into the container from this file via docker-compose.yaml.
SEED_ADMIN_USER=admin
SEED_ADMIN_PASSWORD=replace_with_strong_password
SEED_ADMIN_TEAM=Management
